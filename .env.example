# Copy to .env.local. All VITE_* vars are bundled into the client, so only
# put values here that are safe for anyone to see in devtools.
#
# Airtable credentials must NEVER appear in this file — they live only in
# the Worker (see worker/.dev.vars.example / `wrangler secret put`).

VITE_API_URL=https://hkfc-api.squad-selections.workers.dev
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
